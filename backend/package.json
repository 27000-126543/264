{
  "name": "molecular-spectrum-backend",
  "version": "1.0.0",
  "description": "高精度分子光谱模拟平台后端服务",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "ts-node-dev --transpile-only src/seedData.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fs-extra": "^11.2.0",
    "helmet": "^7.1.0",
    "json2csv": "^6.0.0-alpha.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/json2csv": "^5.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
